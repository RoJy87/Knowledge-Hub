# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_USER=knowledge_hub
DB_PASSWORD=knowledge_hub_password
DB_NAME=knowledge_hub
DB_PORT=5432
DATABASE_URL=postgresql://knowledge_hub:knowledge_hub_password@localhost:5432/knowledge_hub

# JWT Configuration
